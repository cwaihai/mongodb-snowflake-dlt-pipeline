# Copy to terraform.tfvars — never commit to git.

# Find your account ID in Snowflake UI > bottom-left account menu > "Copy account identifier"
# Format is: orgname-accountname  (e.g. myorg-ab12345) — split into the two fields below
snowflake_organization_name = "myorg"
snowflake_account_name      = "ab12345"

snowflake_admin_user                   = "ACCOUNTADMIN_USER"
snowflake_admin_private_key_path       = "~/.ssh/snowflake_rsa_key.p8"
snowflake_admin_private_key_passphrase = ""   # leave empty if key is unencrypted

dlt_sf_username = "DLT_USER"
dlt_sf_password = "DltPipelinePass123!"
