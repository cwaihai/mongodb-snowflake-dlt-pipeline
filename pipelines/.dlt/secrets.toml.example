# Copy this file to secrets.toml and fill in your values.
# secrets.toml is in .gitignore — never commit it.

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
[sources.mongodb]
connection_string = "mongodb+srv://dlt_pipeline_user:YourPassword@cluster0.xxxxx.mongodb.net"

# ── Snowflake destination ──────────────────────────────────────────────────────
[destination.snowflake]
database          = "DLT_INGEST"
warehouse         = "DLT_WH"

[destination.snowflake.credentials]
database          = "DLT_INGEST"
password          = "DltPipelinePass123!"
username          = "DLT_USER"
host              = "myorg-ab12345.snowflakecomputing.com"
warehouse         = "DLT_WH"
role              = "DLT_ROLE"
